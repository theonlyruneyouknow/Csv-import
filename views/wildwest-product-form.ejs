<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= isEdit ? 'Edit' : 'New' %> Product | Wild West Catalog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .image-upload-area {
            border: 2px dashed #ccc;
            border-radius: 10px;
            padding: 30px;
            text-align: center;
            transition: all 0.3s;
        }
        .image-upload-area:hover {
            border-color: #667eea;
            background: #f8f9fa;
        }
        .uploaded-image {
            position: relative;
            display: inline-block;
            margin: 10px;
        }
        .uploaded-image img {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border-radius: 8px;
            border: 2px solid #dee2e6;
            background: #f8f9fa;
        }
        .uploaded-image img.error {
            opacity: 0.5;
        }
        .remove-image {
            position: absolute;
            top: -10px;
            right: -10px;
            background: #dc3545;
            color: white;
            border: none;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/wildwest/admin">
                <i class="bi bi-flower1"></i> Wild West Catalog Admin
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/wildwest/admin">
                    <i class="bi bi-arrow-left"></i> Back to Admin
                </a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">
                            <i class="bi bi-<%= isEdit ? 'pencil' : 'plus-circle' %>"></i>
                            <%= isEdit ? 'Edit' : 'New' %> Product
                        </h4>
                    </div>
                    <div class="card-body">
                        <form action="/wildwest/admin/<%= isEdit ? 'update/' + product._id : 'create' %>" method="POST">
                            <!-- Basic Information -->
                            <h5 class="mb-3">
                                <i class="bi bi-info-circle"></i> Basic Information
                            </h5>
                            
                            <div class="row mb-3">
                                <div class="col-md-8">
                                    <label class="form-label">Product Name *</label>
                                    <input type="text" name="productName" class="form-control" 
                                           value="<%= product ? product.productName : '' %>" 
                                           required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Variety</label>
                                    <input type="text" name="variety" class="form-control" 
                                           value="<%= product ? product.variety || '' : '' %>" 
                                           placeholder="Heirloom, Hybrid, etc.">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Scientific Name</label>
                                <input type="text" name="scientificName" class="form-control" 
                                       value="<%= product ? product.scientificName || '' : '' %>" 
                                       placeholder="e.g., Helianthus annuus">
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Category *</label>
                                    <select name="category" class="form-select" required>
                                        <option value="">Select Category</option>
                                        <option value="Vegetable" <%= product && product.category === 'Vegetable' ? 'selected' : '' %>>Vegetable</option>
                                        <option value="Flower" <%= product && product.category === 'Flower' ? 'selected' : '' %>>Flower</option>
                                        <option value="Herb" <%= product && product.category === 'Herb' ? 'selected' : '' %>>Herb</option>
                                        <option value="Wildflower Mix" <%= product && product.category === 'Wildflower Mix' ? 'selected' : '' %>>Wildflower Mix</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Subcategory</label>
                                    <input type="text" name="subcategory" class="form-control" 
                                           value="<%= product ? product.subcategory || '' : '' %>" 
                                           placeholder="e.g., Beans - Bush, Sunflower">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Description</label>
                                <textarea name="description" class="form-control" rows="4" 
                                          placeholder="Product description, growing tips, etc."><%= product ? product.description || '' : '' %></textarea>
                            </div>

                            <hr>

                            <!-- Status & Availability -->
                            <h5 class="mb-3">
                                <i class="bi bi-box-seam"></i> Status & Availability
                            </h5>

                            <div class="row mb-4">
                                <div class="col-md-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="isActive" 
                                               id="isActive" value="true"
                                               <%= !product || product.isActive ? 'checked' : '' %>>
                                        <label class="form-check-label" for="isActive">
                                            Active
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="inStock" 
                                               id="inStock" value="true"
                                               <%= !product || product.inStock ? 'checked' : '' %>>
                                        <label class="form-check-label" for="inStock">
                                            In Stock
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" name="featured" 
                                               id="featured" value="true"
                                               <%= product && product.featured ? 'checked' : '' %>>
                                        <label class="form-check-label" for="featured">
                                            Featured
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <% if (isEdit && product) { %>
                            <hr>
                            
                            <!-- Images Section -->
                            <h5 class="mb-3">
                                <i class="bi bi-images"></i> Product Images
                            </h5>

                            <!-- Existing Images -->
                            <% if (product.images && product.images.length > 0) { %>
                            <div class="mb-3">
                                <label class="form-label">Current Images</label>
                                <div id="existingImages">
                                    <% product.images.forEach(function(img, index) { %>
                                    <div class="uploaded-image" id="image-<%= index %>">
                                        <img src="<%- img.url %>" 
                                             alt="<%= product.productName %>" 
                                             loading="lazy"
                                             style="object-fit: cover;">
                                        <button type="button" class="remove-image" 
                                                onclick="removeImage('<%= product._id %>', <%= index %>)">
                                            <i class="bi bi-x"></i>
                                        </button>
                                        <% if (img.isPrimary) { %>
                                        <div class="text-center mt-1">
                                            <span class="badge bg-primary">Primary</span>
                                        </div>
                                        <% } %>
                                    </div>
                                    <% }) %>
                                </div>
                            </div>
                            <% } %>

                            <!-- Upload New Image -->
                            <div class="mb-3">
                                <label class="form-label">Add New Image</label>
                                <div class="image-upload-area" id="uploadArea">
                                    <i class="bi bi-cloud-upload" style="font-size: 3rem; color: #667eea;"></i>
                                    <p class="mt-3 mb-2">Click to upload or drag and drop</p>
                                    <p class="small text-muted">JPG, PNG or WebP (Max 5MB)</p>
                                    <input type="file" id="imageInput" accept="image/*" style="display: none;">
                                </div>
                                <div id="uploadProgress" class="mt-3" style="display: none;">
                                    <div class="progress">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                             role="progressbar" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>
                            <% } %>

                            <hr>

                            <!-- Form Actions -->
                            <div class="d-flex justify-content-between">
                                <a href="/wildwest/admin" class="btn btn-secondary">
                                    <i class="bi bi-x-circle"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i> <%= isEdit ? 'Update' : 'Create' %> Product
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <% if (isEdit && product) { %>
                <!-- Quick Tips -->
                <div class="card mt-4 border-info">
                    <div class="card-body">
                        <h6 class="text-info">
                            <i class="bi bi-lightbulb"></i> Tips
                        </h6>
                        <ul class="small mb-0">
                            <li>Upload clear, high-quality product images for better presentation</li>
                            <li>The first image uploaded becomes the primary image automatically</li>
                            <li>Use subcategories to organize varieties (e.g., "Beans - Bush", "Beans - Pole")</li>
                            <li>Mark products as "Featured" to display them on the home page</li>
                        </ul>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <% if (isEdit && product) { %>
    <script>
        // Image upload functionality
        const uploadArea = document.getElementById('uploadArea');
        const imageInput = document.getElementById('imageInput');
        const uploadProgress = document.getElementById('uploadProgress');

        uploadArea.addEventListener('click', function() {
            imageInput.click();
        });

        imageInput.addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append('image', file);

            try {
                uploadProgress.style.display = 'block';
                const progressBar = uploadProgress.querySelector('.progress-bar');
                
                const response = await fetch('/wildwest/admin/<%= product._id %>/upload-image', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    alert('Image uploaded successfully!');
                    window.location.reload();
                } else {
                    alert('Error uploading image: ' + data.message);
                }
            } catch (error) {
                alert('Error uploading image: ' + error.message);
            } finally {
                uploadProgress.style.display = 'none';
                imageInput.value = '';
            }
        });

        // Remove image function
        async function removeImage(productId, imageIndex) {
            if (!confirm('Are you sure you want to remove this image?')) {
                return;
            }

            try {
                const response = await fetch(`/wildwest/admin/${productId}/image/${imageIndex}`, {
                    method: 'DELETE'
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById(`image-${imageIndex}`).remove();
                    alert('Image removed successfully!');
                    window.location.reload();
                } else {
                    alert('Error removing image: ' + data.message);
                }
            } catch (error) {
                alert('Error removing image: ' + error.message);
            }
        }
    </script>
    <% } %>
</body>
</html>
