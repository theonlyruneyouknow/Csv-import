<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= category %> Seeds | Wild West Seed Catalog</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .product-card {
            border: none;
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s;
            height: 100%;
        }
        .product-card:hover {
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
            transform: translateY(-3px);
        }
        .product-card img {
            height: 250px;
            object-fit: cover;
            width: 100%;
        }
        .product-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: #667eea;
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }
        .filter-sidebar {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
        }
        .filter-badge {
            display: inline-block;
            background: #667eea;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            margin: 3px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/wildwest">
                <i class="bi bi-flower1"></i> Wild West Seed Catalog
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/wildwest">Home</a>
                    </li>
                    <% if (user) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/wildwest/admin">
                            <i class="bi bi-gear"></i> Admin
                        </a>
                    </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Page Header -->
    <div class="bg-primary text-white py-4">
        <div class="container">
            <div class="row align-items-center">
                <div class="col">
                    <h1 class="mb-2">
                        <i class="bi bi-<%= category === 'Vegetable' ? 'basket' : category === 'Flower' ? 'flower2' : category === 'Herb' ? 'tree' : 'flower3' %>"></i>
                        <%= category %> Seeds
                    </h1>
                    <p class="mb-0"><%= products.length %> varieties available</p>
                </div>
                <div class="col-auto">
                    <a href="/wildwest" class="btn btn-light">
                        <i class="bi bi-arrow-left"></i> Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container my-5">
        <div class="row">
            <!-- Filters Sidebar -->
            <div class="col-lg-3 mb-4">
                <div class="filter-sidebar">
                    <h5 class="mb-4">
                        <i class="bi bi-funnel"></i> Filters
                    </h5>
                    
                    <form action="/wildwest/category/<%= categorySlug %>" method="GET">
                        <!-- Subcategory Filter -->
                        <% if (subcategories && subcategories.length > 0) { %>
                        <div class="mb-4">
                            <h6 class="mb-3">Type</h6>
                            <select name="subcategory" class="form-select" onchange="this.form.submit()">
                                <option value="">All Types</option>
                                <% subcategories.forEach(function(subcat) { %>
                                <option value="<%= subcat %>" <%= currentFilters.subcategory === subcat ? 'selected' : '' %>>
                                    <%= subcat %>
                                </option>
                                <% }) %>
                            </select>
                        </div>
                        <% } %>

                        <!-- Quick Filters -->
                        <div class="mb-3">
                            <h6 class="mb-3">Quick Filters</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="featured" value="true" 
                                       id="filterFeatured" <%= currentFilters.featured ? 'checked' : '' %>
                                       onchange="this.form.submit()">
                                <label class="form-check-label" for="filterFeatured">
                                    Featured Only
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="organic" value="true" 
                                       id="filterOrganic" <%= currentFilters.organic ? 'checked' : '' %>
                                       onchange="this.form.submit()">
                                <label class="form-check-label" for="filterOrganic">
                                    Organic
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="inStock" value="true" 
                                       id="filterStock" <%= currentFilters.inStock ? 'checked' : '' %>
                                       onchange="this.form.submit()">
                                <label class="form-check-label" for="filterStock">
                                    In Stock
                                </label>
                            </div>
                        </div>

                        <!-- Clear Filters -->
                        <% if (currentFilters.subcategory || currentFilters.featured || currentFilters.organic || currentFilters.inStock) { %>
                        <a href="/wildwest/category/<%= categorySlug %>" class="btn btn-outline-secondary btn-sm w-100">
                            <i class="bi bi-x-circle"></i> Clear Filters
                        </a>
                        <% } %>
                    </form>

                    <!-- Active Filters Display -->
                    <% if (currentFilters.subcategory || currentFilters.featured || currentFilters.organic || currentFilters.inStock) { %>
                    <div class="mt-4">
                        <small class="text-muted">Active Filters:</small>
                        <div class="mt-2">
                            <% if (currentFilters.subcategory) { %>
                            <span class="filter-badge"><%= currentFilters.subcategory %></span>
                            <% } %>
                            <% if (currentFilters.featured) { %>
                            <span class="filter-badge">Featured</span>
                            <% } %>
                            <% if (currentFilters.organic) { %>
                            <span class="filter-badge">Organic</span>
                            <% } %>
                            <% if (currentFilters.inStock) { %>
                            <span class="filter-badge">In Stock</span>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Products Grid -->
            <div class="col-lg-9">
                <% if (products && products.length > 0) { %>
                <div class="row g-4">
                    <% products.forEach(function(product) { %>
                    <div class="col-sm-6 col-lg-4">
                        <div class="card product-card shadow-sm">
                            <div class="position-relative">
                                <% if (product.primaryImage) { %>
                                <img src="<%- product.primaryImage %>" 
                                     class="card-img-top" 
                                     alt="<%= product.productName %>"
                                     loading="lazy"
                                     style="max-width: 100%; height: auto; object-fit: cover;">
                                <% } else { %>
                                <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 250px;">
                                    <i class="bi bi-image" style="font-size: 3rem;"></i>
                                </div>
                                <% } %>
                                <% if (product.getDisplayBadge()) { %>
                                <span class="product-badge"><%= product.getDisplayBadge() %></span>
                                <% } %>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title"><%= product.productName %></h5>
                                <% if (product.scientificName) { %>
                                <p class="text-muted small mb-2">
                                    <em><%= product.scientificName %></em>
                                </p>
                                <% } %>
                                <% if (product.subcategory) { %>
                                <p class="text-secondary small mb-3">
                                    <i class="bi bi-tag"></i> <%= product.subcategory %>
                                </p>
                                <% } %>
                                <% if (product.description) { %>
                                <p class="small text-muted" style="max-height: 60px; overflow: hidden;">
                                    <%= product.description.substring(0, 100) %><%= product.description.length > 100 ? '...' : '' %>
                                </p>
                                <% } %>
                                <a href="/wildwest/product/<%= product.slug %>" class="btn btn-outline-primary btn-sm w-100">
                                    View Details <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h3 class="mt-3">No Products Found</h3>
                    <p class="text-muted">Try adjusting your filters or browse all categories.</p>
                    <a href="/wildwest/category/<%= categorySlug %>" class="btn btn-primary">
                        Clear Filters
                    </a>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">© 2024 Wild West Seed Catalog | Premium Quality Seeds</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
