                ],
                loginRequired: true,
                url: '/greatestjoy/familycircles'
            },
            musicbox: {
                title: '🎼 Music Box Library',
                description: 'Music and video resource library for worship and ministry.',
                features: [
                    '✅ Music collection management',
                    '✅ Video resource library',
                    '✅ Playlist creation',
                    '✅ Media categorization',
                    '✅ Easy search and access'
                ],
                loginRequired: true,
                url: '/musicbox'
            },
            email: {
                title: '📧 Email Client',
                description: 'Integrated email communication system for team coordination and ministry outreach.',
                features: [
                    '✅ Send and receive emails',
                    '✅ Email templates',
                    '✅ Contact management',
                    '✅ Email scheduling',
                    '✅ Thread organization'
                ],
                loginRequired: true,
                url: '/email-client'
            }
        };

        // Handle module selector change
        document.getElementById('moduleSelector').addEventListener('change', function() {
            const selectedModule = this.value;
            const detailsDiv = document.getElementById('moduleDetails');
            
            if (!selectedModule) {
                detailsDiv.style.display = 'none';
                return;
            }
            
            const module = moduleDetails[selectedModule];
            if (!module) return;
            
            const loginBadge = module.loginRequired 
                ? '<span style="background: rgba(255,193,7,0.3); padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid #ffc107;"><i class="fas fa-lock"></i> Login Required</span>'
                : '<span style="background: rgba(40,167,69,0.3); padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.9rem; border: 1px solid #28a745;"><i class="fas fa-unlock"></i> Public Access</span>';
            
            const moduleUrl = module.loginRequired ? `/auth/login?returnTo=${module.url}` : module.url;
            
            detailsDiv.innerHTML = `
                <div style="text-align: left;">
                    <h3 style="color: #ffd700; margin-bottom: 0.5rem; font-size: 1.8rem;">
                        ${module.title}
                    </h3>
                    <div style="margin-bottom: 1rem;">
                        ${loginBadge}
                    </div>
                    <p style="color: white; margin-bottom: 1rem; font-size: 1.1rem;">
                        ${module.description}
                    </p>
                    <h4 style="color: white; margin-bottom: 0.5rem; font-size: 1.2rem;">
                        <i class="fas fa-star"></i> Key Features:
                    </h4>
                    <ul style="color: white; text-align: left; font-size: 1rem; line-height: 1.8;">
                        ${module.features.map(feature => `<li>${feature}</li>`).join('')}
                    </ul>
                    ${module.loginRequired 
                        ? '<p style="color: #ffd700; margin-top: 1rem;"><i class="fas fa-info-circle"></i> Please sign in to access this module.</p>'
                        : '<p style="color: #4ade80; margin-top: 1rem;"><i class="fas fa-info-circle"></i> This module is accessible without login.</p>'
                    }
                    <div style="text-align: center; margin-top: 1.5rem;">
                        <a href="${moduleUrl}" class="btn btn-primary-hero" style="display: inline-block; text-decoration: none;">
                            <i class="fas fa-arrow-right me-2"></i>
                            Go to ${module.title.split(' ')[1] || 'Module'}
                        </a>
                    </div>
                </div>
            `;
            
            detailsDiv.style.display = 'block';
            
            // Smooth scroll to details
            detailsDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
        
        // Add loading state to login button
        document.addEventListener('DOMContentLoaded', function() {
            const loginBtn = document.getElementById('loginBtn');
            if (loginBtn) {
                loginBtn.addEventListener('click', function(e) {
                    const icon = this.querySelector('i');
                    const originalIcon = icon.className;
                    
                    // Show loading state
                    icon.className = 'loading me-2';
                    this.style.pointerEvents = 'none';
                    
                    // Restore after navigation (in case it fails)
                    setTimeout(() => {
                        icon.className = originalIcon;
                        this.style.pointerEvents = 'auto';
                    }, 3000);
                });
            }
            
            // Auto-dismiss alerts after 5 seconds
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    if (alert.parentNode) {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    }
                }, 5000);
            });
        });

        // Add subtle parallax effect to particles
        window.addEventListener('scroll', function() {
            const particles = document.querySelectorAll('.particle');
            const scrolled = window.pageYOffset;
            
            particles.forEach((particle, index) => {
                const speed = 0.5 + (index * 0.1);
                const yPos = -(scrolled * speed);
                particle.style.transform = `translateY(${yPos}px)`;
            });
        });
    </script>
</body>
</html>
