<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TSC Purchase Order Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --success-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--primary-gradient);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .splash-container {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        /* Animated background particles */
        .particles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .particle {
            position: absolute;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            animation: float 6s ease-in-out infinite;
        }

        .particle:nth-child(1) { width: 80px; height: 80px; left: 10%; animation-delay: 0s; }
        .particle:nth-child(2) { width: 60px; height: 60px; left: 20%; animation-delay: 1s; }
        .particle:nth-child(3) { width: 40px; height: 40px; left: 70%; animation-delay: 2s; }
        .particle:nth-child(4) { width: 100px; height: 100px; left: 80%; animation-delay: 3s; }
        .particle:nth-child(5) { width: 50px; height: 50px; left: 60%; animation-delay: 4s; }

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            33% { transform: translateY(-30px) rotate(120deg); }
            66% { transform: translateY(20px) rotate(240deg); }
        }

        /* Header */
        .splash-header {
            padding: 1rem 0;
            position: relative;
            z-index: 10;
        }

        .navbar-brand {
            color: white !important;
            font-weight: 700;
            font-size: 1.5rem;
        }

        .navbar-brand i {
            margin-right: 0.5rem;
            color: #ffd700;
        }

        /* Main content */
        .splash-main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            z-index: 10;
            padding: 2rem 0;
        }

        .hero-content {
            text-align: center;
            color: white;
            max-width: 800px;
            padding: 3rem;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            animation: slideUp 1s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .hero-icon {
            font-size: 4rem;
            margin-bottom: 1.5rem;
            color: #ffd700;
            text-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
        }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            text-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            line-height: 1.2;
        }

        .hero-subtitle {
            font-size: 1.3rem;
            margin-bottom: 2rem;
            opacity: 0.9;
            font-weight: 300;
        }

        .hero-description {
            font-size: 1.1rem;
            margin-bottom: 3rem;
            opacity: 0.8;
            line-height: 1.6;
        }

        /* Action buttons */
        .action-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 2rem;
        }

        .btn-hero {
            padding: 0.75rem 2rem;
            font-size: 1.1rem;
            font-weight: 600;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
            min-width: 150px;
        }

        .btn-primary-hero {
            background: var(--success-gradient);
            color: white;
        }

        .btn-primary-hero:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(0, 0, 0, 0.3);
            color: white;
        }

        .btn-outline-hero {
            background: transparent;
            color: white;
            border: 2px solid rgba(255, 255, 255, 0.6);
        }

        .btn-outline-hero:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-3px);
            color: white;
            border-color: white;
        }

        /* Features section */
        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .feature {
            text-align: center;
            padding: 1.5rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            color: white;
            display: block;
        }

        .feature:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.1);
            color: white;
            text-decoration: none;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
        }

        .feature-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            color: #ffd700;
        }

        .feature-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .feature-text {
            opacity: 0.8;
            font-size: 0.95rem;
        }

        /* Footer */
        .splash-footer {
            padding: 1.5rem 0;
            text-align: center;
            color: rgba(255, 255, 255, 0.7);
            position: relative;
            z-index: 10;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Flash messages */
        .flash-messages {
            position: fixed;
            top: 2rem;
            right: 2rem;
            z-index: 1000;
            max-width: 400px;
        }

        .alert {
            border: none;
            border-radius: 10px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            animation: slideInRight 0.5s ease-out;
        }

        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(100%);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* Responsive design */
        @media (max-width: 768px) {
            .hero-title {
                font-size: 2.5rem;
            }
            
            .hero-subtitle {
                font-size: 1.1rem;
            }
            
            .hero-content {
                margin: 1rem;
                padding: 2rem;
            }
            
            .action-buttons {
                flex-direction: column;
                align-items: center;
            }
            
            .features {
                grid-template-columns: 1fr;
            }
        }

        /* Loading animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="splash-container">
        <!-- Animated background particles -->
        <div class="particles">
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
        </div>

        <!-- Flash Messages -->
        <% if (typeof messages !== 'undefined') { %>
            <div class="flash-messages">
                <% if (messages.error && messages.error.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <%= messages.error[0] %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <% if (messages.success && messages.success.length > 0) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        <%= messages.success[0] %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                
                <% if (messages.info && messages.info.length > 0) { %>
                    <div class="alert alert-info alert-dismissible fade show" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        <%= messages.info[0] %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
            </div>
        <% } %>

        <!-- Header -->
        <header class="splash-header">
            <div class="container">
                <nav class="navbar">
                    <a class="navbar-brand" href="/">
                        <i class="fas fa-home"></i>
                        TSC Management System
                    </a>
                </nav>
            </div>
        </header>

        <!-- Main Content -->
        <main class="splash-main">
            <div class="container">
                <div class="hero-content">
                    <div class="hero-icon">
                        <i class="fas fa-th-large"></i>
                    </div>
                    
                    <h1 class="hero-title">TSC Management Portal</h1>
                    <p class="hero-subtitle">All Your Tools, One Place</p>
                    
                    <p class="hero-description">
                        Welcome to TSC's comprehensive management system. Access all your ministry tools, 
                        from purchase orders to food management, hymns to family resources, all in one secure platform.
                    </p>
                    
                    <!-- Module Navigation Dropdown -->
                    <div style="max-width: 500px; margin: 0 auto 2rem auto;">
                        <label for="moduleSelector" style="display: block; margin-bottom: 0.5rem; color: white; font-weight: 600;">
                            <i class="fas fa-compass"></i> Explore Our Modules:
                        </label>
                        <select id="moduleSelector" class="form-select" style="font-size: 1.1rem; padding: 0.75rem; border-radius: 10px; border: 2px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.9);">
                            <option value="">-- Select a Module to Learn More --</option>
                            <option value="pod">📦 Purchase Orders (P.O.D.)</option>
                            <option value="food">🍽️ Food Management</option>
                            <option value="story">📖 Story Resources</option>
                            <option value="medicine">💊 Medicine Management</option>
                            <option value="bulletin">📋 Bulletin Board</option>
                            <option value="hymns">🎵 Hymn Search</option>
                            <option value="ebm">🌟 Elder Brother Mission</option>
                            <option value="grocery">🛒 Grocery Management</option>
                            <option value="greatestjoy">💫 Greatest Joy</option>
                            <option value="familycircles">👨‍👩‍👧 Family Circles</option>
                            <option value="musicbox">🎼 Music Box Library</option>
                            <option value="email">📧 Email Client</option>
                        </select>
                    </div>
                    
                    <!-- Login/Registration Buttons -->
                    <div class="action-buttons">
                        <% if (typeof user !== 'undefined' && user) { %>
                            <!-- User is logged in -->
                            <a href="/purchase-orders" class="btn btn-primary-hero">
                                <i class="fas fa-tachometer-alt me-2"></i>
                                Go to Dashboard
                            </a>
                            <a href="/auth/logout" class="btn btn-outline-hero">
                                <i class="fas fa-sign-out-alt me-2"></i>
                                Logout
                            </a>
                        <% } else { %>
                            <!-- User is not logged in -->
                            <a href="/auth/login" class="btn btn-primary-hero" id="loginBtn">
                                <i class="fas fa-sign-in-alt me-2"></i>
                                Sign In
                            </a>
                            <a href="/auth/register" class="btn btn-outline-hero">
                                <i class="fas fa-user-plus me-2"></i>
                                Register
                            </a>
                        <% } %>
                    </div>
                    
                    <!-- Module Details (shown when selected) -->
                    <div id="moduleDetails" style="display: none; margin-top: 2rem; padding: 1.5rem; background: rgba(255,255,255,0.15); border-radius: 15px; border: 2px solid rgba(255,255,255,0.3);">
                        <!-- Content will be dynamically inserted -->
                    </div>
                </div>
            </div>
        </main>

        <!-- All Modules Overview -->
        <section style="background: rgba(0,0,0,0.2); padding: 3rem 0; position: relative; z-index: 10;">
            <div class="container">
                <h2 style="color: white; text-align: center; margin-bottom: 2rem; font-size: 2.5rem;">
                    <i class="fas fa-box-open"></i> Available Modules
                </h2>
                
                <div class="row g-4">
                    <!-- Purchase Orders -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/purchase-orders" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #667eea;">
                                <i class="fas fa-boxes"></i>
                            </div>
                            <h3 class="feature-title">Purchase Orders (P.O.D.)</h3>
                            <p class="feature-text">Manage purchase orders, track inventory, vendor management, and receiving operations.</p>
                        </a>
                    </div>
                    
                    <!-- Food Management -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/food-dashboard" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #dc3545;">
                                <i class="fas fa-utensils"></i>
                            </div>
                            <h3 class="feature-title">Food Management</h3>
                            <p class="feature-text">Recipes, meal planning, pantry tracking, and shopping list management in one place.</p>
                        </a>
                    </div>
                    
                    <!-- Story Resources -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/story/dashboard" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #ff6b6b;">
                                <i class="fas fa-book-open"></i>
                            </div>
                            <h3 class="feature-title">Story Resources</h3>
                            <p class="feature-text">Access and manage teaching stories, illustrations, and educational narratives.</p>
                        </a>
                    </div>
                    
                    <!-- Medicine Management -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/medicine/dashboard" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #28a745;">
                                <i class="fas fa-pills"></i>
                            </div>
                            <h3 class="feature-title">Medicine Management</h3>
                            <p class="feature-text">Track medications, dosages, prescriptions, and medical supply inventory.</p>
                        </a>
                    </div>
                    
                    <!-- Bulletin Board -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/bulletin" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #ffc107;">
                                <i class="fas fa-clipboard"></i>
                            </div>
                            <h3 class="feature-title">Bulletin Board</h3>
                            <p class="feature-text">Post announcements, share updates, and keep everyone informed.</p>
                        </a>
                    </div>
                    
                    <!-- Hymn Search -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/hymns" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #17a2b8;">
                                <i class="fas fa-music"></i>
                            </div>
                            <h3 class="feature-title">Hymn Search</h3>
                            <p class="feature-text">Search and browse hymns by title, number, lyrics, or theme for worship services.</p>
                        </a>
                    </div>
                    
                    <!-- EBM -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/ebm/dashboard" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #e83e8c;">
                                <i class="fas fa-hands-helping"></i>
                            </div>
                            <h3 class="feature-title">Elder Brother Mission</h3>
                            <p class="feature-text">Missionary area tracking, companionships, and mission field management tools.</p>
                        </a>
                    </div>
                    
                    <!-- Grocery Management -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/grocery/dashboard" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #20c997;">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                            <h3 class="feature-title">Grocery Management</h3>
                            <p class="feature-text">Organize grocery shopping, track expenses, and manage household supplies.</p>
                        </a>
                    </div>
                    
                    <!-- Greatest Joy -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/greatestjoy/dashboard" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #fd7e14;">
                                <i class="fas fa-heart"></i>
                            </div>
                            <h3 class="feature-title">Greatest Joy</h3>
                            <p class="feature-text">Ministry resources, teaching materials, and spiritual growth tools.</p>
                        </a>
                    </div>
                    
                    <!-- Family Circles -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/greatestjoy/familycircles" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #6f42c1;">
                                <i class="fas fa-users"></i>
                            </div>
                            <h3 class="feature-title">Family Circles</h3>
                            <p class="feature-text">Family ministry coordination, group activities, and relationship building.</p>
                        </a>
                    </div>
                    
                    <!-- Music Box -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/musicbox" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #3498db;">
                                <i class="fas fa-compact-disc"></i>
                            </div>
                            <h3 class="feature-title">Music Box Library</h3>
                            <p class="feature-text">Access music and video resources, organize media collections.</p>
                        </a>
                    </div>
                    
                    <!-- Email Client -->
                    <div class="col-md-6 col-lg-4">
                        <a href="/auth/login?returnTo=/email-client" class="feature" style="height: 100%; background: rgba(255,255,255,0.1);">
                            <div class="feature-icon" style="color: #95a5a6;">
                                <i class="fas fa-envelope"></i>
                            </div>
                            <h3 class="feature-title">Email Client</h3>
                            <p class="feature-text">Integrated email communication system for team coordination.</p>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="splash-footer">
            <div class="container">
                <p>&copy; <%= new Date().getFullYear() %> TSC Management System. All rights reserved.</p>
                <p>
                    <small>
                        <i class="fas fa-shield-alt me-2"></i>
                        Secure, reliable, and built for ministry excellence
                    </small>
                </p>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Module details data
        const moduleDetails = {
