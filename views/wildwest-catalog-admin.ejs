<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wild West Catalog Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .stat-card {
            border: none;
            border-radius: 12px;
            padding: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            margin-bottom: 20px;
        }
        .stat-number {
            font-size: 2.5rem;
            font-weight: bold;
        }
        .table-img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/wildwest">
                <i class="bi bi-flower1"></i> Wild West Catalog Admin
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/wildwest">
                    <i class="bi bi-house"></i> Public View
                </a>
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4">
        <!-- Statistics -->
        <div class="row mb-4">
            <div class="col-md-2">
                <div class="stat-card">
                    <div class="stat-number"><%= stats.total %></div>
                    <div>Total Products</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="stat-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                    <div class="stat-number"><%= stats.vegetables %></div>
                    <div>Vegetables</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="stat-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                    <div class="stat-number"><%= stats.flowers %></div>
                    <div>Flowers</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="stat-card" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                    <div class="stat-number"><%= stats.herbs %></div>
                    <div>Herbs</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="stat-card" style="background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);">
                    <div class="stat-number"><%= stats.wildflowers %></div>
                    <div>Wildflowers</div>
                </div>
            </div>
            <div class="col-md-2">
                <div class="stat-card" style="background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);">
                    <div class="stat-number"><%= stats.noImages %></div>
                    <div>No Images</div>
                </div>
            </div>
        </div>

        <!-- Filters and Actions -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-3">
                        <form action="/wildwest/admin" method="GET" class="d-flex gap-2">
                            <select name="category" class="form-select" onchange="this.form.submit()">
                                <option value="all" <%= currentFilter === 'all' ? 'selected' : '' %>>All Categories</option>
                                <option value="Vegetable" <%= currentFilter === 'Vegetable' ? 'selected' : '' %>>Vegetables</option>
                                <option value="Flower" <%= currentFilter === 'Flower' ? 'selected' : '' %>>Flowers</option>
                                <option value="Herb" <%= currentFilter === 'Herb' ? 'selected' : '' %>>Herbs</option>
                                <option value="Wildflower Mix" <%= currentFilter === 'Wildflower Mix' ? 'selected' : '' %>>Wildflower Mixes</option>
                            </select>
                        </form>
                    </div>
                    <div class="col-md-6">
                        <form action="/wildwest/admin" method="GET" class="d-flex gap-2">
                            <input type="text" name="search" class="form-control" placeholder="Search products..." value="<%= searchTerm || '' %>">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i> Search
                            </button>
                        </form>
                    </div>
                    <div class="col-md-3 text-end">
                        <a href="/wildwest/admin/new" class="btn btn-success">
                            <i class="bi bi-plus-circle"></i> New Product
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Table -->
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-list-ul"></i> Products
                    <span class="badge bg-secondary"><%= products.length %></span>
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Subcategory</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (products && products.length > 0) { %>
                            <% products.forEach(function(product) { %>
                            <tr>
                                <td>
                                    <% if (product.primaryImage) { %>
                                    <img src="<%- product.primaryImage %>" 
                                         class="table-img" 
                                         alt="<%= product.productName %>"
                                         loading="lazy"
                                         style="object-fit: cover;">
                                    <% } else { %>
                                    <div class="table-img bg-secondary d-flex align-items-center justify-content-center text-white">
                                        <i class="bi bi-image"></i>
                                    </div>
                                    <% } %>
                                </td>
                                <td>
                                    <div>
                                        <strong><%= product.productName %></strong>
                                        <% if (product.featured) { %>
                                        <span class="badge bg-primary ms-2">Featured</span>
                                        <% } %>
                                    </div>
                                    <% if (product.scientificName) { %>
                                    <small class="text-muted">
                                        <em><%= product.scientificName %></em>
                                    </small>
                                    <% } %>
                                </td>
                                <td>
                                    <span class="badge bg-info">
                                        <%= product.category %>
                                    </span>
                                </td>
                                <td>
                                    <%= product.subcategory || '-' %>
                                </td>
                                <td>
                                    <% if (product.isActive) { %>
                                    <span class="badge bg-success">Active</span>
                                    <% } else { %>
                                    <span class="badge bg-secondary">Inactive</span>
                                    <% } %>
                                    <br>
                                    <% if (product.inStock) { %>
                                    <span class="badge bg-success mt-1">In Stock</span>
                                    <% } else { %>
                                    <span class="badge bg-danger mt-1">Out of Stock</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/wildwest/product/<%= product.slug %>" 
                                           class="btn btn-outline-primary" 
                                           title="View" 
                                           target="_blank">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/wildwest/admin/edit/<%= product._id %>" 
                                           class="btn btn-outline-secondary" 
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button class="btn btn-outline-danger" 
                                                title="Delete" 
                                                onclick="deleteProduct('<%= product._id %>', '<%= product.productName %>')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                            <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                                    <p class="text-muted mt-3">No products found</p>
                                    <a href="/wildwest/admin/new" class="btn btn-primary">
                                        <i class="bi bi-plus-circle"></i> Add Your First Product
                                    </a>
                                </td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function deleteProduct(id, name) {
            if (!confirm(`Are you sure you want to delete "${name}"?`)) {
                return;
            }
            
            try {
                const response = await fetch(`/wildwest/admin/${id}`, {
                    method: 'DELETE'
                });
                
                const data = await response.json();
                
                if (data.success) {
                    alert('Product deleted successfully');
                    window.location.reload();
                } else {
                    alert('Error deleting product: ' + data.message);
                }
            } catch (error) {
                alert('Error deleting product: ' + error.message);
            }
        }
    </script>
</body>
</html>
