<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bulk Upload Photos - Greatest Joy</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <%- include('partials/user-dropdown-styles') %>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            background: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .upload-container {
            max-width: 1200px;
            margin: 40px auto;
            background: white;
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        }

        .upload-title {
            text-align: center;
            margin-bottom: 30px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .dropzone {
            border: 3px dashed #667eea;
            border-radius: 12px;
            padding: 60px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: #f8f9fa;
        }

        .dropzone:hover,
        .dropzone.dragover {
            background: #e8ecff;
            border-color: #764ba2;
        }

        .dropzone-icon {
            font-size: 64px;
            color: #667eea;
            margin-bottom: 20px;
        }

        .preview-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .preview-item {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            background: white;
        }

        .preview-item img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .preview-item .remove-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            background: rgba(220, 53, 69, 0.9);
            color: white;
            border: none;
            border-radius: 50%;
            width: 32px;
            height: 32px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .preview-item .file-name {
            padding: 10px;
            font-size: 0.85em;
            color: #666;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
        }

        .progress {
            display: none;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="header">
        <div>
            <a href="/greatestjoy/dashboard" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to Gallery
            </a>
        </div>
        <% if (typeof user !== 'undefined' && user) { %>
            <div>
                <%- include('partials/user-dropdown', { user: user }) %>
            </div>
        <% } %>
    </div>

    <div class="upload-container">
        <h2 class="upload-title">
            <i class="fas fa-folder-open"></i> Bulk Upload Photos from Folder
        </h2>

        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            <strong>How it works:</strong> Upload multiple photos at once, then click on each photo later to add stories, voice recordings, and details.
        </div>

        <div class="alert alert-success">
            <i class="fas fa-cloud"></i>
            <strong>Tip:</strong> Have photos in Google Photos or Google Drive? 
            <a href="/greatestjoy/cloud-import" class="alert-link">Import directly from cloud storage</a> instead!
        </div>

        <!-- Dropzone -->
        <div class="dropzone" id="dropzone">
            <div class="dropzone-icon">
                <i class="fas fa-cloud-upload-alt"></i>
            </div>
            <h4>Drag & Drop Photos Here</h4>
            <p class="text-muted">or click to browse your computer</p>
            <p class="text-muted"><small>Supports: JPG, PNG, GIF, MP4, MOV</small></p>
            <input type="file" id="fileInput" multiple accept="image/*,video/*" style="display: none;">
        </div>

        <!-- Common Info Form -->
        <div id="commonInfoSection" style="display: none; margin-top: 30px;">
            <h5 class="mb-3">Apply Common Info to All Photos (Optional)</h5>
            <div class="row">
                <div class="col-md-4">
                    <label class="form-label">Album Name</label>
                    <input type="text" class="form-control" id="commonAlbum" placeholder="e.g., Summer 2026">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Location</label>
                    <input type="text" class="form-control" id="commonLocation" placeholder="e.g., Grandma's House">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Date Taken</label>
                    <input type="date" class="form-control" id="commonDate" value="<%= new Date().toISOString().split('T')[0] %>">
                </div>
            </div>
        </div>

        <!-- Preview Grid -->
        <div id="previewGrid" class="preview-grid"></div>

        <!-- Upload Button -->
        <div id="uploadSection" style="display: none; margin-top: 30px;">
            <div class="progress">
                <div class="progress-bar" role="progressbar" style="width: 0%"></div>
            </div>
            <div class="d-grid gap-2">
                <button class="btn btn-primary btn-lg" id="uploadBtn">
                    <i class="fas fa-upload me-2"></i>Upload <span id="fileCount">0</span> Photos
                </button>
            </div>
            <p class="text-center text-muted mt-3">
                <small>After upload, you can click each photo to add stories and voice recordings</small>
            </p>
        </div>
    </div>

    <script>
        const dropzone = document.getElementById('dropzone');
        const fileInput = document.getElementById('fileInput');
        const previewGrid = document.getElementById('previewGrid');
        const uploadSection = document.getElementById('uploadSection');
        const commonInfoSection = document.getElementById('commonInfoSection');
        const uploadBtn = document.getElementById('uploadBtn');
        const fileCountSpan = document.getElementById('fileCount');
        
        let selectedFiles = [];

        // Click to browse
        dropzone.addEventListener('click', () => fileInput.click());

        // Drag and drop
        dropzone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropzone.classList.add('dragover');
        });

        dropzone.addEventListener('dragleave', () => {
            dropzone.classList.remove('dragover');
        });

        dropzone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropzone.classList.remove('dragover');
            handleFiles(e.dataTransfer.files);
        });

        // File input change
        fileInput.addEventListener('change', (e) => {
            handleFiles(e.target.files);
        });

        function handleFiles(files) {
            for (let file of files) {
                if (file.type.startsWith('image/') || file.type.startsWith('video/')) {
                    selectedFiles.push(file);
                    addPreview(file);
                }
            }
            updateUI();
        }

        function addPreview(file) {
            const reader = new FileReader();
            reader.onload = (e) => {
                const div = document.createElement('div');
                div.className = 'preview-item';
                div.dataset.fileName = file.name;
                
                const isVideo = file.type.startsWith('video/');
                const mediaElement = isVideo ? 
                    `<video src="${e.target.result}" style="width: 100%; height: 200px; object-fit: cover;"></video>` :
                    `<img src="${e.target.result}" alt="${file.name}">`;
                
                div.innerHTML = `
                    ${mediaElement}
                    <button class="remove-btn" onclick="removeFile('${file.name}')">
                        <i class="fas fa-times"></i>
                    </button>
                    <div class="file-name">${file.name}</div>
                `;
                previewGrid.appendChild(div);
            };
            reader.readAsDataURL(file);
        }

        window.removeFile = function(fileName) {
            selectedFiles = selectedFiles.filter(f => f.name !== fileName);
            const preview = document.querySelector(`[data-file-name="${fileName}"]`);
            if (preview) preview.remove();
            updateUI();
        }

        function updateUI() {
            fileCountSpan.textContent = selectedFiles.length;
            if (selectedFiles.length > 0) {
                uploadSection.style.display = 'block';
                commonInfoSection.style.display = 'block';
            } else {
                uploadSection.style.display = 'none';
                commonInfoSection.style.display = 'none';
            }
        }

        uploadBtn.addEventListener('click', async () => {
            if (selectedFiles.length === 0) return;

            uploadBtn.disabled = true;
            const progress = document.querySelector('.progress');
            const progressBar = document.querySelector('.progress-bar');
            progress.style.display = 'block';

            const album = document.getElementById('commonAlbum').value;
            const location = document.getElementById('commonLocation').value;
            const captureDate = document.getElementById('commonDate').value;

            let uploaded = 0;

            for (let file of selectedFiles) {
                try {
                    // For now, we'll need to upload to a storage service
                    // This is a placeholder - you'd need to implement actual file upload
                    // to a service like AWS S3, Cloudinary, or your own server
                    
                    const formData = new FormData();
                    formData.append('title', file.name.replace(/\.[^/.]+$/, ""));
                    formData.append('mediaType', file.type.startsWith('video/') ? 'video' : 'photo');
                    formData.append('album', album);
                    formData.append('location', location);
                    formData.append('captureDate', captureDate);
                    formData.append('file', file);

                    const response = await fetch('/greatestjoy/upload-file', {
                        method: 'POST',
                        body: formData
                    });

                    if (response.ok) {
                        uploaded++;
                        const percent = (uploaded / selectedFiles.length) * 100;
                        progressBar.style.width = percent + '%';
                        progressBar.textContent = Math.round(percent) + '%';
                    }
                } catch (error) {
                    console.error('Upload error:', error);
                }
            }

            alert(`Successfully uploaded ${uploaded} of ${selectedFiles.length} files!`);
            window.location.href = '/greatestjoy/dashboard';
        });
    </script>
</body>
</html>
